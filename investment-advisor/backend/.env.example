# Environment variables for Investment Advisor System
# Copy this file to .env and fill in your values

# API Keys (optional - some data sources may require keys)
ALPHA_VANTAGE_API_KEY=your_api_key_here
NEWS_API_KEY=your_news_api_key_here

# Model settings
MODEL_PATH=models/lgb_portfolio.joblib
FEATURE_IMPORTANCE_PATH=models/feature_importance.json

# Data settings
CACHE_DIR=data/cache
RAW_DATA_DIR=data/raw
FEATURES_DIR=data/features

# Prediction settings
PREDICTION_HORIZON=1  # days
CONFIDENCE_THRESHOLD=0.5
DEFAULT_TICKERS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,JPM,V,JNJ

# Server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
